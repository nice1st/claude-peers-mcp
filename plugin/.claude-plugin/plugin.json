{
  "name": "claude-peers",
  "description": "Peer discovery and messaging channel for Claude Code",
  "version": "0.2.0",
  "author": {
    "name": "nice1st"
  },
  "homepage": "https://github.com/nice1st/claude-peers-mcp",
  "repository": "https://github.com/nice1st/claude-peers-mcp",
  "keywords": ["peers", "messaging", "channel", "collaboration"],
  "mcpServers": {
    "claude-peers": {
      "command": "bun",
      "args": ["run", "--cwd", "${CLAUDE_PLUGIN_ROOT}", "--shell=bun", "--silent", "start"],
      "env": {
        "CLAUDE_PEERS_BROKER_URL": "${CLAUDE_PEERS_BROKER_URL}"
      }
    }
  }
}
